parser code
{:
    public LinkedList<ErrorSintactico> erroresSintacticos = new LinkedList<>();

    private static class ParAtributo {
        String nombre;
        Expresion valor;
        LinkedList<Expresion> lista;
        LinkedList<Instruccion> bloque;
        ExpresionWhoIsThatPokemon pokemon;

        ParAtributo(String nombre, Expresion valor) {
            this.nombre = nombre;
            this.valor = valor;
        }

        ParAtributo(String nombre, LinkedList<Expresion> lista) {
            this.nombre = nombre;
            this.lista = lista;
        }

        ParAtributo(String nombre, LinkedList<Instruccion> bloque, boolean esBloque) {
            this.nombre = nombre;
            this.bloque = bloque;
        }

        ParAtributo(String nombre, ExpresionWhoIsThatPokemon pokemon) {
            this.nombre = nombre;
            this.pokemon = pokemon;
        }
    }

    private Expresion obtenerExpresion(LinkedList<ParAtributo> atributos, String nombre) {
        for (ParAtributo atributo : atributos) {
            if (atributo.nombre.equalsIgnoreCase(nombre) && atributo.valor != null) {
                return atributo.valor;
            }
        }
        return null;
    }

    private LinkedList<Expresion> obtenerLista(LinkedList<ParAtributo> atributos, String nombre) {
        for (ParAtributo atributo : atributos) {
            if (atributo.nombre.equalsIgnoreCase(nombre) && atributo.lista != null) {
                return atributo.lista;
            }
        }
        return new LinkedList<Expresion>();
    }

    private LinkedList<Instruccion> obtenerBloque(LinkedList<ParAtributo> atributos, String nombre) {
        for (ParAtributo atributo : atributos) {
            if (atributo.nombre.equalsIgnoreCase(nombre) && atributo.bloque != null) {
                return atributo.bloque;
            }
        }
        return new LinkedList<Instruccion>();
    }

    private ExpresionWhoIsThatPokemon obtenerPokemon(LinkedList<ParAtributo> atributos, String nombre) {
        for (ParAtributo atributo : atributos) {
            if (atributo.nombre.equalsIgnoreCase(nombre) && atributo.pokemon != null) {
                return atributo.pokemon;
            }
        }
        return null;
    }

    private Expresion obtenerTexto(LinkedList<ParAtributo> atributos, int fila, int columna) {
        Expresion content = obtenerExpresion(atributos, "content");
        if (content != null) return content;
        Expresion label = obtenerExpresion(atributos, "label");
        if (label != null) return label;
        return new ExpresionLiteral(TiposDato.STRING, "", fila, columna);
    }

    private String normalizarClaveEstilo(String clave) {
        String limpia = clave.toLowerCase().trim().replace(" ", "_");
        if (limpia.equals("color")) return "style_color";
        if (limpia.equals("background_color")) return "style_background";
        if (limpia.equals("font_family")) return "style_font";
        if (limpia.equals("text_size")) return "style_text_size";
        if (limpia.equals("border")) return "style_border";
        return "style_" + limpia;
    }

    @Override
    public void syntax_error(Symbol simbolo) {
        erroresSintacticos.add(new ErrorSintactico(
            "No se esperaba el componente " + simbolo.value,
            simbolo.left,
            simbolo.right
        ));
    }

    @Override
    public void unrecovered_syntax_error(Symbol simbolo) throws Exception {
        erroresSintacticos.add(new ErrorSintactico(
            "No se pudo recuperar del componente " + simbolo.value,
            simbolo.left,
            simbolo.right
        ));
    }
:}

terminal String ID, CADENA, ENTERO, DECIMAL;
terminal SECTION, TABLE, TEXT, OPEN_QUESTION, DROP_QUESTION, SELECT_QUESTION, MULTIPLE_QUESTION;
terminal IF, ELSE, WHILE, DO, FOR, IN;
terminal SPECIAL, DRAW, WHO_IS_THAT_POKEMON, ELEMENTS, STYLES;
terminal NUMBER, STRING, TRUE, FALSE;
terminal OPTIONS, CORRECT;
terminal MAS, MENOS, MULT, DIV, MOD, NOT, OR, AND;
terminal IGUALDAD, DIFERENTE, MAYOR, MENOR, MAYOR_IGUAL, MENOR_IGUAL;
terminal ASIGNACION, PUNTO_Y_COMA, DOS_PUNTOS, COMA, PUNTO, PARENTESIS_IZQ, PARENTESIS_DER, LLAVE_IZQ, LLAVE_DER, CORCHETE_IZQ, CORCHETE_DER, RANGO;

non terminal LinkedList<Instruccion> INICIO, INSTRUCCIONES, BLOQUE, ELSE_BLOCK;
non terminal Instruccion INSTRUCCION, INSTRUCCION_SIMPLE, IF_O_ELSEIF, FOR_INICIAL, FOR_ACTUALIZACION, PROTOTIPO_ESPECIAL;
non terminal Expresion EXPRESION;
non terminal ExpresionWhoIsThatPokemon EXPRESION_POKEMON;
non terminal LinkedList<ParAtributo> LISTA_ATRIBUTOS, ATRIBUTOS_ESTILO, LISTA_ESTILOS, LISTA_ESTILOS_OPT;
non terminal ParAtributo ATRIBUTO, ATRIBUTO_ESTILO;
non terminal LinkedList<Expresion> LISTA_EXPRESIONES, LISTA_EXPRESIONES_OPT;
non terminal String CLAVE_ESTILO;

precedence left OR;
precedence left AND;
precedence right NOT;
precedence left IGUALDAD, DIFERENTE, MENOR, MENOR_IGUAL, MAYOR, MAYOR_IGUAL;
precedence left MAS, MENOS;
precedence left MULT, DIV, MOD;

start with INICIO;

INICIO ::= INSTRUCCIONES:a {: RESULT = a; :}
;

INSTRUCCIONES ::= INSTRUCCIONES:a INSTRUCCION:b {: RESULT = a; RESULT.add(b); :}
                | INSTRUCCION:a {: RESULT = new LinkedList<Instruccion>(); RESULT.add(a); :}
;

BLOQUE ::= LLAVE_IZQ INSTRUCCIONES:a LLAVE_DER {: RESULT = a; :}
         | LLAVE_IZQ LLAVE_DER {: RESULT = new LinkedList<Instruccion>(); :}
;

INSTRUCCION ::= INSTRUCCION_SIMPLE:a {: RESULT = a; :}
              | IF_O_ELSEIF:a {: RESULT = a; :}
              | WHILE:a PARENTESIS_IZQ EXPRESION:b PARENTESIS_DER BLOQUE:c
                {: RESULT = new InstruccionWhile(b, c, aleft, aright); :}
              | DO:a BLOQUE:b WHILE PARENTESIS_IZQ EXPRESION:c PARENTESIS_DER PUNTO_Y_COMA
                {: RESULT = new InstruccionDoWhile(b, c, aleft, aright); :}
              | FOR:a PARENTESIS_IZQ FOR_INICIAL:b PUNTO_Y_COMA EXPRESION:c PUNTO_Y_COMA FOR_ACTUALIZACION:d PARENTESIS_DER BLOQUE:e
                {: RESULT = new InstruccionFor(b, c, d, e, aleft, aright); :}
              | FOR:a PARENTESIS_IZQ ID:b IN:c EXPRESION:d RANGO EXPRESION:e PARENTESIS_DER BLOQUE:f
                {: RESULT = new InstruccionForRango(b, d, e, f, aleft, aright); :}
;

IF_O_ELSEIF ::= IF:a PARENTESIS_IZQ EXPRESION:b PARENTESIS_DER BLOQUE:c ELSE_BLOCK:d
                {: RESULT = new InstruccionIf(b, c, d, aleft, aright); :}
;

ELSE_BLOCK ::= ELSE IF_O_ELSEIF:a
               {:
                   RESULT = new LinkedList<Instruccion>();
                   RESULT.add(a);
               :}
             | ELSE BLOQUE:a {: RESULT = a; :}
             | {: RESULT = new LinkedList<Instruccion>(); :}
;

FOR_INICIAL ::= ID:a ASIGNACION EXPRESION:b {: RESULT = new InstruccionForInicial(a, b, aleft, aright); :}
;

FOR_ACTUALIZACION ::= ID:a ASIGNACION EXPRESION:b {: RESULT = new InstruccionAsignacion(a, b, aleft, aright); :}
;

INSTRUCCION_SIMPLE ::= NUMBER:a ID:b PUNTO_Y_COMA {: RESULT = new InstruccionDeclaracion(TiposDato.NUMBER, b, null, aleft, aright); :}
                     | NUMBER:a ID:b ASIGNACION EXPRESION:c PUNTO_Y_COMA {: RESULT = new InstruccionDeclaracion(TiposDato.NUMBER, b, c, aleft, aright); :}
                     | STRING:a ID:b PUNTO_Y_COMA {: RESULT = new InstruccionDeclaracion(TiposDato.STRING, b, null, aleft, aright); :}
                     | STRING:a ID:b ASIGNACION EXPRESION:c PUNTO_Y_COMA {: RESULT = new InstruccionDeclaracion(TiposDato.STRING, b, c, aleft, aright); :}
                     | ID:a ASIGNACION EXPRESION:b PUNTO_Y_COMA {: RESULT = new InstruccionAsignacion(a, b, aleft, aright); :}

                     | SECTION:a ID:b PUNTO_Y_COMA
                       {: RESULT = new InstruccionSection(new ExpresionAccesoVariable(b, aleft, aright), null, null, null, null, null, null, null, null, null, new LinkedList<Instruccion>(), aleft, aright); :}
                     | SECTION:a CADENA:b PUNTO_Y_COMA
                       {: RESULT = new InstruccionSection(new ExpresionLiteral(TiposDato.STRING, b, aleft, aright), null, null, null, null, null, null, null, null, null, new LinkedList<Instruccion>(), aleft, aright); :}
                     | SECTION:a CORCHETE_IZQ LISTA_ATRIBUTOS:b CORCHETE_DER PUNTO_Y_COMA
