                               correctos,
                               obtenerExpresion(b, "style_color"),
                               obtenerExpresion(b, "style_background"),
                               obtenerExpresion(b, "style_font"),
                               obtenerExpresion(b, "style_text_size"),
                               obtenerExpresion(b, "style_border"),
                               aleft,
                               aright
                           );
                       :}
;

LISTA_ATRIBUTOS ::= LISTA_ATRIBUTOS:a COMA ATRIBUTO:b {: RESULT = a; RESULT.add(b); :}
                  | LISTA_ATRIBUTOS:a COMA ATRIBUTOS_ESTILO:b {: RESULT = a; RESULT.addAll(b); :}
                  | ATRIBUTO:a {: RESULT = new LinkedList<ParAtributo>(); RESULT.add(a); :}
                  | ATRIBUTOS_ESTILO:a {: RESULT = a; :}
;

ATRIBUTOS_ESTILO ::= STYLES CORCHETE_IZQ LISTA_ESTILOS_OPT:a CORCHETE_DER {: RESULT = a; :}
;

LISTA_ESTILOS_OPT ::= LISTA_ESTILOS:a {: RESULT = a; :}
                    | {: RESULT = new LinkedList<ParAtributo>(); :}
;

LISTA_ESTILOS ::= LISTA_ESTILOS:a COMA ATRIBUTO_ESTILO:b {: RESULT = a; RESULT.add(b); :}
                | ATRIBUTO_ESTILO:a {: RESULT = new LinkedList<ParAtributo>(); RESULT.add(a); :}
;

ATRIBUTO_ESTILO ::= CLAVE_ESTILO:a DOS_PUNTOS EXPRESION:b {: RESULT = new ParAtributo(normalizarClaveEstilo(a), b); :}
;

CLAVE_ESTILO ::= ID:a {: RESULT = a; :}
               | CADENA:a {: RESULT = a; :}
;

ATRIBUTO ::= ID:a DOS_PUNTOS EXPRESION:b {: RESULT = new ParAtributo(a, b); :}
           | OPTIONS:a DOS_PUNTOS LLAVE_IZQ LISTA_EXPRESIONES_OPT:b LLAVE_DER {: RESULT = new ParAtributo("options", b); :}
           | OPTIONS:a DOS_PUNTOS EXPRESION_POKEMON:b {: RESULT = new ParAtributo("options", b); :}
           | CORRECT:a DOS_PUNTOS LLAVE_IZQ LISTA_EXPRESIONES_OPT:b LLAVE_DER {: RESULT = new ParAtributo("correct", b); :}
           | CORRECT:a DOS_PUNTOS EXPRESION:b {: RESULT = new ParAtributo("correct", b); :}
           | ELEMENTS:a DOS_PUNTOS BLOQUE:b {: RESULT = new ParAtributo("elements", b, true); :}
;

EXPRESION_POKEMON ::= WHO_IS_THAT_POKEMON:a PARENTESIS_IZQ NUMBER COMA EXPRESION:b COMA EXPRESION:c PARENTESIS_DER
                     {: RESULT = new ExpresionWhoIsThatPokemon(b, c, aleft, aright); :}
;

LISTA_EXPRESIONES_OPT ::= LISTA_EXPRESIONES:a {: RESULT = a; :}
                        | {: RESULT = new LinkedList<Expresion>(); :}
;

LISTA_EXPRESIONES ::= LISTA_EXPRESIONES:a COMA EXPRESION:b {: RESULT = a; RESULT.add(b); :}
                    | EXPRESION:a {: RESULT = new LinkedList<Expresion>(); RESULT.add(a); :}
;

EXPRESION ::= EXPRESION:a MAS EXPRESION:b {: RESULT = new ExpresionBinaria(a, "+", b, aleft, aright); :}
            | EXPRESION:a MENOS EXPRESION:b {: RESULT = new ExpresionBinaria(a, "-", b, aleft, aright); :}
            | EXPRESION:a MULT EXPRESION:b {: RESULT = new ExpresionBinaria(a, "*", b, aleft, aright); :}
            | EXPRESION:a DIV EXPRESION:b {: RESULT = new ExpresionBinaria(a, "/", b, aleft, aright); :}
            | EXPRESION:a MOD EXPRESION:b {: RESULT = new ExpresionBinaria(a, "%", b, aleft, aright); :}
            | EXPRESION:a IGUALDAD EXPRESION:b {: RESULT = new ExpresionBinaria(a, "==", b, aleft, aright); :}
            | EXPRESION:a DIFERENTE EXPRESION:b {: RESULT = new ExpresionBinaria(a, "!=", b, aleft, aright); :}
            | EXPRESION:a MAYOR EXPRESION:b {: RESULT = new ExpresionBinaria(a, ">", b, aleft, aright); :}
            | EXPRESION:a MENOR EXPRESION:b {: RESULT = new ExpresionBinaria(a, "<", b, aleft, aright); :}
            | EXPRESION:a MAYOR_IGUAL EXPRESION:b {: RESULT = new ExpresionBinaria(a, ">=", b, aleft, aright); :}
            | EXPRESION:a MENOR_IGUAL EXPRESION:b {: RESULT = new ExpresionBinaria(a, "<=", b, aleft, aright); :}
            | EXPRESION:a OR EXPRESION:b {: RESULT = new ExpresionBinaria(a, "||", b, aleft, aright); :}
            | EXPRESION:a AND EXPRESION:b {: RESULT = new ExpresionBinaria(a, "&&", b, aleft, aright); :}
            | MENOS:a EXPRESION:b {: RESULT = new ExpresionUnaria("-", b, aleft, aright); :}
            | NOT:a EXPRESION:b {: RESULT = new ExpresionUnaria("~", b, aleft, aright); :}
            | PARENTESIS_IZQ EXPRESION:a PARENTESIS_DER {: RESULT = a; :}
            | ENTERO:a {: RESULT = new ExpresionLiteral(TiposDato.NUMBER, Double.parseDouble(a), aleft, aright); :}
            | DECIMAL:a {: RESULT = new ExpresionLiteral(TiposDato.NUMBER, Double.parseDouble(a), aleft, aright); :}
            | CADENA:a {: RESULT = new ExpresionLiteral(TiposDato.STRING, a, aleft, aright); :}
            | TRUE:a {: RESULT = new ExpresionLiteral(TiposDato.BOOLEAN, true, aleft, aright); :}
            | FALSE:a {: RESULT = new ExpresionLiteral(TiposDato.BOOLEAN, false, aleft, aright); :}
            | ID:a {: RESULT = new ExpresionAccesoVariable(a, aleft, aright); :}
;
